source "https://rubygems.org"

# Happy Jekylling!
gem "jekyll"

# This is the default theme for new Jekyll sites.
gem "minima", "~> 2.5"

# Example plugin
gem "jekyll-feed", "~> 0.12", group: :jekyll_plugins

# If you are using Ruby version 3.0.0 or higher you need webrick as
# well to be able to serve.
# See https://github.com/jekyll/jekyll/issues/8523
gem "webrick"

# Windows and JRuby does not include zoneinfo files, so bundle the
# tzinfo-data gem and associated library.
platforms :mingw, :x64_mingw, :mswin, :jruby do
  gem "tzinfo", "~> 1.2"
  gem "tzinfo-data"
end

# Performance-booster for watching directories on Windows
gem "wdm", "~> 0.1.1", :platforms => [:mingw, :x64_mingw, :mswin]




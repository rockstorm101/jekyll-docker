source "https://rubygems.org"

# Happy Jekylling!
gem "jekyll", "~> 4.2.2"

# This is the default theme for new Jekyll sites.
gem "minima", "~> 2.5"

# Jekyll plugins
group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.12"
end

# If you are using Ruby version 3.0.0 or higher you need webrick as
# well to be able to serve.
# See https://github.com/jekyll/jekyll/issues/8523
gem "webrick"
